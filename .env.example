# Nest LangGraph AI - Environment Variables
# Copy this to .env and fill in your values.
# Required vars have no defaults - set them!
# Optional vars show defaults in comments.

# === REQUIRED ===
MISTRAL_API_KEY=sk-proj-...  # Mistral AI API key (get from console.mistral.ai)
TAVILY_API_KEY=tvly-...      # Tavily search API key (tavily.com)
REDIS_HOST=localhost         # Redis host (Compose app service overrides this to "redis")
REDIS_PORT=6379              # Redis port

# === OPTIONAL ===
PORT=3000                    # Server port
MISTRAL_MODEL=mistral-small-latest
MISTRAL_TIMEOUT_MS=30000     # LLM request timeout (ms)
CORS_ORIGIN=*                # CORS allowed origins (comma-separated or *)
AGENT_MAX_ITERATIONS=3       # Max agent graph iterations (1-10)
AGENT_MAX_RETRIES=3          # Max retries per step (1-10)
TOOL_TIMEOUT_MS=15000        # Tool execution timeout (ms)
AGENT_WORKING_DIR=/path/to/working/dir  # Compose app service overrides this to /workspace
CACHE_TTL_SECONDS=60         # Redis cache TTL (seconds)
SESSION_TTL_SECONDS=86400    # Session TTL (seconds)
CRITIC_RESULT_MAX_CHARS=8000 # Max chars for critic to review
PROMPT_MAX_ATTEMPTS=5        # Max recent attempts shown in prompts
PROMPT_MAX_SUMMARY_CHARS=2000
QDRANT_URL=http://localhost:6333  # Qdrant URL (Compose app service overrides this to http://qdrant:6333)
QDRANT_COLLECTION=agent_vectors   # Qdrant collection name
QDRANT_CHECK_COMPATIBILITY=false  # Skip version warnings when Qdrant is unavailable
QDRANT_VECTOR_SIZE=384       # Embedding dimension (matches all-MiniLM-L6-v2)

# === NEWLY ADDED ===
NODE_ENV=development         # 'development', 'production', etc.
ENABLE_SWAGGER=false         # 'true' to enable Swagger docs (even in production)
