{
  "name": "nest-langgraph-ai",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "_moduleAliases": {
    "@config": "dist/common/config",
    "@utils": "dist/common/utils",
    "@common": "dist/common",
    "@llm": "dist/modules/llm",
    "@redis": "dist/modules/redis",
    "@agents": "dist/modules/agents",
    "@nodes": "dist/modules/agents/nodes",
    "@tools": "dist/modules/agents/tools",
    "@state": "dist/modules/agents/state",
    "@graph": "dist/modules/agents/graph",
    "@vector-db": "dist/modules/vector-db",
    "@health": "dist/modules/health"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node -r tsconfig-paths/register dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --watchman=false",
    "test:watch": "jest --watch --watchman=false",
    "test:cov": "jest --coverage --watchman=false",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:first": "standard-version --first-release",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d --build",
    "docker:up:tools": "docker compose -f docker/docker-compose.yml --profile tools up -d --build",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:clean": "docker compose -f docker/docker-compose.yml down -v --rmi all && docker builder prune -f",
    "docker:fresh": "npm run docker:clean && npm run docker:up"
  },
  "dependencies": {
    "@langchain/community": "^1.1.23",
    "@langchain/core": "^1.1.32",
    "@langchain/langgraph": "^1.2.2",
    "@langchain/langgraph-checkpoint": "^1.0.0",
    "@langchain/mistralai": "^1.0.7",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "@tavily/core": "^0.7.2",
    "@xenova/transformers": "^2.17.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "dotenv": "^17.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "joi": "^18.0.2",
    "langchain": "^1.2.31",
    "module-alias": "^2.3.4",
    "node-fetch": "^3.3.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^7.6.0",
    "@nestjs/schematics": "^7.3.1",
    "@nestjs/testing": "^11.0.1",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.15",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "standard-version": "^9.5.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/src/$1",
      "^@config/(.*)$": "<rootDir>/src/common/config/$1",
      "^@utils/(.*)$": "<rootDir>/src/common/utils/$1",
      "^@common/(.*)$": "<rootDir>/src/common/$1",
      "^@llm/(.*)$": "<rootDir>/src/modules/llm/$1",
      "^@redis/(.*)$": "<rootDir>/src/modules/redis/$1",
      "^@agents/(.*)$": "<rootDir>/src/modules/agents/$1",
      "^@nodes/(.*)$": "<rootDir>/src/modules/agents/nodes/$1",
      "^@tools/(.*)$": "<rootDir>/src/modules/agents/tools/$1",
      "^@state/(.*)$": "<rootDir>/src/modules/agents/state/$1",
      "^@graph/(.*)$": "<rootDir>/src/modules/agents/graph/$1"
    }
  }
}
