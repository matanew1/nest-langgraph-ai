flowchart TD
  %% NestJS + LangGraph multi-agent workflow (17 nodes)
  %% Source of truth: agent-topology.ts, agent-node-names.ts, agent-phase.ts

  START(["__START__"])
  END(["__END__"])

  SUPERVISOR["supervisor"]
  RESEARCHER_COORDINATOR["researcher_coordinator"]
  RESEARCH_FS["research_fs"]
  RESEARCH_VECTOR["research_vector"]
  RESEARCH_JOIN["research_join"]
  PLANNER["planner"]
  PLAN_VALIDATOR["plan_validator"]
  AWAIT_PLAN_REVIEW["await_plan_review"]
  EXECUTE["execute"]
  EXECUTE_PARALLEL["execute_parallel"]
  TOOL_RESULT_NORMALIZER["tool_result_normalizer"]
  CRITIC["critic"]
  GENERATOR["generator"]
  MEMORY_PERSIST["memory_persist"]
  CHAT["chat"]
  TERMINAL_RESPONSE["terminal_response"]
  ROUTER["router"]

  %% ── Entry ──
  START --> SUPERVISOR

  %% ── Nodes that return to ROUTER (standard edges) ──
  SUPERVISOR --> ROUTER
  RESEARCH_JOIN --> ROUTER
  PLANNER --> ROUTER
  PLAN_VALIDATOR --> ROUTER
  AWAIT_PLAN_REVIEW --> ROUTER
  EXECUTE --> ROUTER
  EXECUTE_PARALLEL --> ROUTER
  TOOL_RESULT_NORMALIZER --> ROUTER
  CRITIC --> ROUTER
  CHAT --> ROUTER
  TERMINAL_RESPONSE --> ROUTER

  %% ── Research parallel fan-out / fan-in ──
  RESEARCHER_COORDINATOR -->|"Send()"| RESEARCH_FS
  RESEARCHER_COORDINATOR -->|"Send()"| RESEARCH_VECTOR
  RESEARCH_FS --> RESEARCH_JOIN
  RESEARCH_VECTOR --> RESEARCH_JOIN

  %% ── Generator dual output ──
  GENERATOR --> ROUTER
  GENERATOR --> MEMORY_PERSIST

  %% ── Memory persist terminal ──
  MEMORY_PERSIST --> END

  %% ── Conditional edges from ROUTER ──
  ROUTER -->|"phase = complete"| END
  ROUTER -->|"phase = fatal"| TERMINAL_RESPONSE

  ROUTER -->|"phase = supervisor"| SUPERVISOR
  ROUTER -->|"phase = research"| RESEARCHER_COORDINATOR
  ROUTER -->|"phase = research_join"| RESEARCH_JOIN
  ROUTER -->|"phase = plan"| PLANNER
  ROUTER -->|"phase = validate_plan"| PLAN_VALIDATOR
  ROUTER -->|"phase = await_plan_review"| AWAIT_PLAN_REVIEW
  ROUTER -->|"phase = execute"| EXECUTE
  ROUTER -->|"phase = execute_parallel"| EXECUTE_PARALLEL
  ROUTER -->|"phase = normalize_tool_result"| TOOL_RESULT_NORMALIZER
  ROUTER -->|"phase = judge"| CRITIC
  ROUTER -->|"phase = generate"| GENERATOR
  ROUTER -->|"phase = chat"| CHAT
  ROUTER -->|"phase = fatal_recovery"| TERMINAL_RESPONSE
  ROUTER -->|"phase = clarification"| TERMINAL_RESPONSE

  %% ── Fallback ──
  ROUTER -.->|"unknown phase / fallback"| SUPERVISOR

  %% ── Valid phase transitions (for reference) ──
  %% SUPERVISOR → research | chat | clarification | fatal
  %% RESEARCH → research_join | fatal
  %% RESEARCH_JOIN → plan | fatal
  %% PLAN → validate_plan | fatal
  %% VALIDATE_PLAN → execute | execute_parallel | await_plan_review | fatal
  %% EXECUTE → normalize_tool_result | fatal
  %% EXECUTE_PARALLEL → normalize_tool_result | fatal
  %% NORMALIZE_TOOL_RESULT → judge | fatal
  %% JUDGE → route | fatal
  %% ROUTE → supervisor | research | execute | execute_parallel | generate | fatal | complete
  %% GENERATE → complete | fatal
  %% CHAT → complete | fatal
